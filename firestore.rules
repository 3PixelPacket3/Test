rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function userDoc() { return get(/databases/$(database)/documents/users/$(request.auth.uid)); }
    function getUserRole() { return isSignedIn() && userDoc().exists() ? userDoc().data.role : 'guest'; }
    function isAdmin() { return getUserRole() in ['admin', 'superadmin']; }
    function isSuperAdmin() { return getUserRole() == 'superadmin'; }

    match /users/{uid} {
      allow create: if isOwner(uid) && request.resource.data.role == 'player';
      allow read: if isOwner(uid) || isAdmin();
      allow update: if (isOwner(uid)
        && request.resource.data.role == resource.data.role
        && request.resource.data.gold == resource.data.gold
        && request.resource.data.silver == resource.data.silver)
        || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    match /products/{id} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    match /developerNotes/{id} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    match /dmLoot/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /adminCodes/{id} {
      allow read: if isAdmin();
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSignedIn() && request.resource.data.redeemed == true && resource.data.redeemed == false);
    }

    match /inventory/{id} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /pokerStats/{uid} {
      allow read, write: if isOwner(uid) || isAdmin();
    }

    match /transactions/{id} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    match /appSettings/{id} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }
  }
}
